# AgentLens Docker 环境变量示例
# 复制为 .env 后修改，docker compose 会自动加载

# 存储后端：file | sqlite | postgresql
TRACE_STORAGE_BACKEND=file

# file 存储目录
TRACE_FILE_STORAGE_DIR=/app/data/traces
# 容器内 /app/data/traces 会被挂载到这个宿主机目录，方便直接查看/备份
TRACE_FILE_STORAGE_HOST_DIR=./data/traces

# SQLite 数据库文件宿主机目录（TRACE_STORAGE_BACKEND=sqlite 时使用）
# 容器内 /app/data/db 会被挂载到这个宿主机目录
TRACE_DB_HOST_DIR=./data/db

# 数据库后端连接串（storage_backend 为 sqlite / postgresql 时使用）
# sqlite: 留空则默认 sqlite+aiosqlite:////app/data/db/traces.db
# postgresql: 必须显式配置（需用 INSTALL_POSTGRES=1 构建镜像安装 asyncpg）
# TRACE_DATABASE_URL=sqlite+aiosqlite:////app/data/db/traces.db
# TRACE_DATABASE_URL=postgresql+asyncpg://agentlens:agentlens@postgres:5432/agentlens

# 端口映射（宿主机侧；容器内端口固定 8000 / 80 不要改）
BACKEND_PORT=8000
FRONTEND_PORT=8080

# 镜像 tag
IMAGE_TAG=0.6.0
