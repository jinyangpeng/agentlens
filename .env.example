# AgentLens Docker 环境变量示例
# 复制为 .env 后修改，docker compose 会自动加载

# 存储后端：memory | file
TRACE_STORAGE_BACKEND=file

# file 存储目录
TRACE_FILE_STORAGE_DIR=/app/data/traces
# 容器内 /app/data/traces 会被挂载到这个宿主机目录，方便直接查看/备份
TRACE_FILE_STORAGE_HOST_DIR=./data/traces

# 端口映射（宿主机侧；容器内端口固定 8000 / 80 不要改）
BACKEND_PORT=8000
FRONTEND_PORT=8080

# 镜像 tag（自定义构建后用）
IMAGE_TAG=0.5.0
