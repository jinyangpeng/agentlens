TRACE_STORAGE_BACKEND=memory
TRACE_FILE_STORAGE_DIR=./data/traces

# 数据库后端（sqlite / postgresql）配置
# sqlite: 留空则默认 sqlite+aiosqlite:///./data/traces.db
# postgresql: 必须显式配置连接串（需安装 asyncpg: pip install -e ".[postgres]"）
# TRACE_DATABASE_URL=sqlite+aiosqlite:///./data/traces.db
# TRACE_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentlens

TRACE_CORS_ORIGINS=["http://localhost:5173"]
TRACE_API_PREFIX=/api/v1
