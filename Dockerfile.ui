# AgentLens UI Dockerfile
# 多阶段：Node 22 构建 → nginx 静态托管

# ---- 阶段 1：构建 ----
FROM node:22-alpine AS builder

WORKDIR /build

# 复制 manifest（利用 Docker 缓存）
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci

# 复制源码并构建
COPY frontend/ ./
RUN npm run build


# ---- 阶段 2：运行时（nginx） ----
FROM nginx:1.27-alpine

LABEL org.opencontainers.image.title="agentlens-ui"
LABEL org.opencontainers.image.description="AgentLens: Web UI for trace visualization"
LABEL org.opencontainers.image.version="0.5.0"

# 删除默认配置
RUN rm /etc/nginx/conf.d/default.conf

# 自定义 nginx 配置：SPA + /api 反代到后端
COPY nginx.conf /etc/nginx/conf.d/agentlens.conf

# 复制构建产物
COPY --from=builder /build/dist /usr/share/nginx/html

# 健康检查
HEALTHCHECK --interval=15s --timeout=3s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost/healthz || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
